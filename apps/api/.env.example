# Copy this file to .env and fill in your own values.
# NEVER commit a real .env file — this project's history had a live Gemini
# key committed to it and that key must be treated as compromised/rotated.
GEMINI_API_KEY=
DATABASE_URL=sqlite:///./evguardian.db
REDIS_URL=redis://redis:6379/0
SECRET_KEY=change-me-to-a-random-secret-in-production
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001
